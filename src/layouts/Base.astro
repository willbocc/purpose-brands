---
import '../styles/global.css';
import { SEO } from 'astro-seo';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import CookieBanner from '../components/CookieBanner.astro';
import PixelBlast from '../components/PixelBlast.astro';
import Grainient from '../components/Grainient.astro';
import BgControlPanel from '../components/BgControlPanel.astro';
import { getSettings } from '../lib/site';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  noindex?: boolean;
  surface?: 'light' | 'dark';
}

const settings = await getSettings();

const {
  title,
  description = settings.description,
  ogImage = '/og-default.png',
  noindex = false,
  surface = 'light',
} = Astro.props;

const fullTitle = title ? `${title} — ${settings.name}` : `${settings.name} — ${settings.tagline}`;
const canonical = new URL(Astro.url.pathname, settings.url).toString();
---

<!doctype html>
<html lang="en-GB">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="canonical" href={canonical} />
    <SEO
      title={fullTitle}
      description={description}
      canonical={canonical}
      noindex={noindex}
      openGraph={{
        basic: {
          title: fullTitle,
          type: 'website',
          image: new URL(ogImage, settings.url).toString(),
          url: canonical,
        },
        optional: {
          description,
          siteName: settings.name,
        },
        image: {
          alt: settings.name,
        },
      }}
      twitter={{ card: 'summary_large_image' }}
    />
    <script is:inline>
      (function () {
        var allowed = ['pixel', 'grainient', 'none'];
        var params = new URLSearchParams(window.location.search);
        var bg = params.get('bg');
        if (!bg || allowed.indexOf(bg) === -1) bg = 'pixel';
        document.documentElement.dataset.bg = bg;
      })();
    </script>
  </head>
  <body class:list={[surface === 'dark' && 'surface-dark']}>
    <a href="#main" class="skip-link">Skip to content</a>
    <div class="site-shell">
      <PixelBlast />
      <Grainient />
      <Nav />
      <main id="main">
        <slot />
      </main>
    </div>
    <Footer />
    <CookieBanner />
    <BgControlPanel />

    <style>
      .site-shell {
        position: relative;
        isolation: isolate;
      }

      .site-shell :global(.pixel-blast),
      .site-shell :global(.grainient) {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 100vh;
        max-height: 900px;
        z-index: 0;
      }

      .site-shell :global(.pixel-blast) {
        opacity: 0.9;
      }

      :global(html[data-bg='grainient']) .site-shell :global(.pixel-blast),
      :global(html[data-bg='none']) .site-shell :global(.pixel-blast) {
        display: none;
      }

      :global(html[data-bg='pixel']) .site-shell :global(.grainient),
      :global(html[data-bg='none']) .site-shell :global(.grainient) {
        display: none;
      }

      .site-shell :global(.site-nav),
      .site-shell > main {
        position: relative;
        z-index: 1;
      }
    </style>

    {settings.ga4MeasurementId && (
      <script is:inline define:vars={{ gaId: settings.ga4MeasurementId }}>
        function loadGa(id) {
          if (window.__gaLoaded) return;
          window.__gaLoaded = true;
          const s = document.createElement('script');
          s.async = true;
          s.src = 'https://www.googletagmanager.com/gtag/js?id=' + id;
          document.head.appendChild(s);
          window.dataLayer = window.dataLayer || [];
          window.gtag = function () { window.dataLayer.push(arguments); };
          window.gtag('js', new Date());
          window.gtag('config', id, { anonymize_ip: true });
        }
        if (localStorage.getItem('pb_consent') === 'granted') {
          loadGa(gaId);
        }
        window.addEventListener('pb:consent-granted', () => loadGa(gaId));
      </script>
    )}
  </body>
</html>
