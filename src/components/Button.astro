---
interface Props {
  href: string;
  variant?: 'primary' | 'secondary' | 'ghost';
  size?: 'md' | 'lg';
  class?: string;
}

const {
  href,
  variant = 'primary',
  size = 'md',
  class: className,
} = Astro.props;
---

<a
  href={href}
  class:list={['btn', `btn--${variant}`, `btn--${size}`, className]}
>
  <slot />
</a>

<style>
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-display);
    font-weight: 700;
    letter-spacing: 0.01em;
    border-radius: 999px;
    transition: background 140ms ease, color 140ms ease, transform 200ms ease;
    white-space: nowrap;
  }

  .btn--md {
    padding: 0.75rem 1.5rem;
    font-size: 0.9375rem;
  }

  .btn--lg {
    padding: 1rem 2rem;
    font-size: 1rem;
  }

  .btn--primary {
    background: #ffffff;
    color: var(--color-brand-purple-ink);
  }

  .btn--primary:hover {
    background: var(--color-accent);
    color: var(--color-brand-purple-ink);
    transform: translateY(-1px);
  }

  .btn--secondary {
    background: transparent;
    color: #ffffff;
    border: 1px solid #ffffff;
  }

  .btn--secondary:hover {
    background: #ffffff;
    color: var(--color-brand-purple-ink);
  }

  .btn--ghost {
    background: transparent;
    color: inherit;
    padding-inline: 0;
  }

  .btn--ghost:hover {
    opacity: 0.7;
  }
</style>
