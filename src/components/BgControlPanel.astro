---
// Floating dev panel: switch background variant + tune live uniforms.
---

<aside class="bg-panel" data-bg-panel aria-label="Background controls">
  <header class="bg-panel__head">
    <strong>Background</strong>
    <button type="button" class="bg-panel__collapse" data-bg-panel-collapse aria-label="Collapse">−</button>
  </header>

  <div class="bg-panel__body" data-bg-panel-body>
    <div class="bg-panel__row bg-panel__toggle">
      <button type="button" data-bg-set="pixel">Pixel</button>
      <button type="button" data-bg-set="grainient">Gradient</button>
      <button type="button" data-bg-set="none">None</button>
    </div>

    <section class="bg-panel__group" data-bg-group="pixel">
      <h4>PixelBlast</h4>
      <div class="bg-panel__controls" data-pixel-controls></div>
    </section>

    <section class="bg-panel__group" data-bg-group="grainient">
      <h4>Grainient</h4>
      <div class="bg-panel__controls" data-grainient-controls></div>
    </section>
  </div>
</aside>

<style>
  .bg-panel {
    position: fixed;
    bottom: 1rem;
    left: 1rem;
    z-index: 60;
    width: 280px;
    max-height: calc(100vh - 2rem);
    background: rgba(20, 22, 60, 0.92);
    color: #fff;
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: 10px;
    backdrop-filter: blur(10px);
    font-family: system-ui, -apple-system, sans-serif;
    font-size: 11px;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    box-shadow: 0 10px 30px -10px rgba(0, 0, 0, 0.6);
  }

  .bg-panel[data-collapsed='1'] .bg-panel__body {
    display: none;
  }

  .bg-panel[data-collapsed='1'] .bg-panel__collapse {
    transform: rotate(180deg);
  }

  .bg-panel__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.5rem 0.75rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.12);
    cursor: grab;
    font-size: 12px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .bg-panel__collapse {
    background: transparent;
    color: #fff;
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 4px;
    width: 22px;
    height: 22px;
    cursor: pointer;
    line-height: 1;
    transition: transform 200ms ease;
  }

  .bg-panel__body {
    overflow-y: auto;
    padding: 0.5rem 0.75rem 0.75rem;
  }

  .bg-panel__toggle {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 4px;
    margin-bottom: 0.75rem;
  }

  .bg-panel__toggle button {
    background: rgba(255, 255, 255, 0.06);
    color: #fff;
    border: 1px solid rgba(255, 255, 255, 0.16);
    border-radius: 6px;
    padding: 6px 8px;
    cursor: pointer;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .bg-panel__toggle button[data-active='1'] {
    background: #f6c453;
    color: #2a2e8e;
    border-color: #f6c453;
    font-weight: 700;
  }

  .bg-panel__group {
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    padding-top: 0.5rem;
  }

  .bg-panel__group h4 {
    font-size: 11px;
    margin: 0 0 0.5rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: rgba(255, 255, 255, 0.6);
  }

  .bg-panel__group[hidden] {
    display: none;
  }

  .bg-panel__control {
    display: grid;
    grid-template-columns: 90px 1fr 42px;
    align-items: center;
    gap: 6px;
    margin-bottom: 4px;
  }

  .bg-panel__control label {
    font-size: 10px;
    color: rgba(255, 255, 255, 0.7);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .bg-panel__control input[type='range'] {
    width: 100%;
    accent-color: #f6c453;
  }

  .bg-panel__control input[type='color'] {
    width: 100%;
    height: 22px;
    background: transparent;
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 4px;
    padding: 0;
    cursor: pointer;
  }

  .bg-panel__control input[type='checkbox'] {
    justify-self: start;
    accent-color: #f6c453;
  }

  .bg-panel__value {
    font-variant-numeric: tabular-nums;
    color: rgba(255, 255, 255, 0.7);
    font-size: 10px;
    text-align: right;
  }

  .bg-panel__control--full {
    grid-template-columns: 90px 1fr;
  }

  .bg-panel__control--full .bg-panel__value {
    display: none;
  }
</style>

<script>
  type PixelKey =
    | 'pixelSize'
    | 'patternScale'
    | 'patternDensity'
    | 'speed'
    | 'edgeFade'
    | 'rippleIntensity'
    | 'rippleSpeed'
    | 'rippleThickness';

  type GrainKey =
    | 'timeSpeed'
    | 'colorBalance'
    | 'warpStrength'
    | 'warpFrequency'
    | 'warpSpeed'
    | 'warpAmplitude'
    | 'blendAngle'
    | 'blendSoftness'
    | 'rotationAmount'
    | 'noiseScale'
    | 'grainAmount'
    | 'grainScale'
    | 'contrast'
    | 'gamma'
    | 'saturation'
    | 'zoom'
    | 'centerX'
    | 'centerY';

  type SliderSpec<K extends string> = {
    key: K;
    label: string;
    min: number;
    max: number;
    step: number;
    uniform: string;
  };

  const PIXEL_SLIDERS: SliderSpec<PixelKey>[] = [
    { key: 'pixelSize', label: 'Pixel size', min: 1, max: 12, step: 0.5, uniform: 'uPixelSize' },
    { key: 'patternScale', label: 'Pattern scale', min: 0.5, max: 10, step: 0.1, uniform: 'uScale' },
    { key: 'patternDensity', label: 'Density', min: 0, max: 2, step: 0.01, uniform: 'uDensity' },
    { key: 'speed', label: 'Speed', min: 0, max: 2, step: 0.01, uniform: '__speed' },
    { key: 'edgeFade', label: 'Edge fade', min: 0, max: 2, step: 0.01, uniform: 'uEdgeFade' },
    { key: 'rippleIntensity', label: 'Ripple force', min: 0, max: 3, step: 0.01, uniform: 'uRippleIntensity' },
    { key: 'rippleSpeed', label: 'Ripple speed', min: 0, max: 1.5, step: 0.01, uniform: 'uRippleSpeed' },
    { key: 'rippleThickness', label: 'Ripple thick', min: 0.02, max: 0.5, step: 0.005, uniform: 'uRippleThickness' },
  ];

  const PIXEL_DEFAULTS: Record<PixelKey, number> = {
    pixelSize: 4,
    patternScale: 2.6,
    patternDensity: 1,
    speed: 0.35,
    edgeFade: 0.7,
    rippleIntensity: 1.2,
    rippleSpeed: 0.35,
    rippleThickness: 0.1,
  };

  const GRAIN_SLIDERS: SliderSpec<GrainKey>[] = [
    { key: 'timeSpeed', label: 'Time speed', min: 0, max: 1, step: 0.01, uniform: 'uTimeSpeed' },
    { key: 'colorBalance', label: 'Balance', min: -0.5, max: 0.5, step: 0.01, uniform: 'uColorBalance' },
    { key: 'warpStrength', label: 'Warp strength', min: 0.1, max: 3, step: 0.01, uniform: 'uWarpStrength' },
    { key: 'warpFrequency', label: 'Warp freq', min: 0.5, max: 15, step: 0.1, uniform: 'uWarpFrequency' },
    { key: 'warpSpeed', label: 'Warp speed', min: 0, max: 5, step: 0.01, uniform: 'uWarpSpeed' },
    { key: 'warpAmplitude', label: 'Warp amp', min: 10, max: 200, step: 1, uniform: 'uWarpAmplitude' },
    { key: 'blendAngle', label: 'Blend angle', min: -180, max: 180, step: 1, uniform: 'uBlendAngle' },
    { key: 'blendSoftness', label: 'Blend soft', min: 0, max: 0.5, step: 0.005, uniform: 'uBlendSoftness' },
    { key: 'rotationAmount', label: 'Rotation', min: 0, max: 720, step: 1, uniform: 'uRotationAmount' },
    { key: 'noiseScale', label: 'Noise scale', min: 0.5, max: 5, step: 0.05, uniform: 'uNoiseScale' },
    { key: 'grainAmount', label: 'Grain amt', min: 0, max: 0.5, step: 0.005, uniform: 'uGrainAmount' },
    { key: 'grainScale', label: 'Grain scale', min: 0.5, max: 10, step: 0.05, uniform: 'uGrainScale' },
    { key: 'contrast', label: 'Contrast', min: 0.5, max: 2, step: 0.01, uniform: 'uContrast' },
    { key: 'gamma', label: 'Gamma', min: 0.5, max: 2, step: 0.01, uniform: 'uGamma' },
    { key: 'saturation', label: 'Saturation', min: 0, max: 2, step: 0.01, uniform: 'uSaturation' },
    { key: 'zoom', label: 'Zoom', min: 0.3, max: 3, step: 0.01, uniform: 'uZoom' },
    { key: 'centerX', label: 'Center X', min: -0.5, max: 0.5, step: 0.01, uniform: '__centerX' },
    { key: 'centerY', label: 'Center Y', min: -0.5, max: 0.5, step: 0.01, uniform: '__centerY' },
  ];

  const GRAIN_DEFAULTS: Record<GrainKey, number> = {
    timeSpeed: 0.18,
    colorBalance: 0,
    warpStrength: 1,
    warpFrequency: 5,
    warpSpeed: 1.4,
    warpAmplitude: 60,
    blendAngle: 0,
    blendSoftness: 0.08,
    rotationAmount: 360,
    noiseScale: 2,
    grainAmount: 0.06,
    grainScale: 2,
    contrast: 1.15,
    gamma: 1,
    saturation: 1,
    zoom: 0.9,
    centerX: 0,
    centerY: 0,
  };

  const pixelApi = () => (window as any).__pixelBlast;
  const grainApi = () => (window as any).__grainient;

  const setActive = (variant: 'pixel' | 'grainient' | 'none') => {
    document.documentElement.dataset.bg = variant;
    document.querySelectorAll<HTMLButtonElement>('[data-bg-set]').forEach((btn) => {
      btn.dataset.active = btn.dataset.bgSet === variant ? '1' : '0';
    });
    document.querySelectorAll<HTMLElement>('[data-bg-group]').forEach((g) => {
      g.hidden = g.dataset.bgGroup !== variant;
    });
    const url = new URL(window.location.href);
    if (variant === 'pixel') url.searchParams.delete('bg');
    else url.searchParams.set('bg', variant);
    history.replaceState(null, '', url.toString());
  };

  const makeSlider = <K extends string>(
    spec: SliderSpec<K>,
    initial: number,
    onInput: (v: number) => void,
  ): HTMLElement => {
    const wrap = document.createElement('div');
    wrap.className = 'bg-panel__control';
    const lbl = document.createElement('label');
    lbl.textContent = spec.label;
    const input = document.createElement('input');
    input.type = 'range';
    input.min = String(spec.min);
    input.max = String(spec.max);
    input.step = String(spec.step);
    input.value = String(initial);
    const val = document.createElement('span');
    val.className = 'bg-panel__value';
    val.textContent = String(initial);
    input.addEventListener('input', () => {
      const v = parseFloat(input.value);
      val.textContent = Number.isInteger(spec.step) ? String(v) : v.toFixed(2);
      onInput(v);
    });
    wrap.append(lbl, input, val);
    return wrap;
  };

  const makeColor = (
    label: string,
    initial: string,
    onInput: (v: string) => void,
  ): HTMLElement => {
    const wrap = document.createElement('div');
    wrap.className = 'bg-panel__control bg-panel__control--full';
    const lbl = document.createElement('label');
    lbl.textContent = label;
    const input = document.createElement('input');
    input.type = 'color';
    input.value = initial;
    input.addEventListener('input', () => onInput(input.value));
    wrap.append(lbl, input);
    return wrap;
  };

  const makeCheckbox = (
    label: string,
    initial: boolean,
    onInput: (v: boolean) => void,
  ): HTMLElement => {
    const wrap = document.createElement('div');
    wrap.className = 'bg-panel__control';
    const lbl = document.createElement('label');
    lbl.textContent = label;
    const input = document.createElement('input');
    input.type = 'checkbox';
    input.checked = initial;
    input.addEventListener('change', () => onInput(input.checked));
    wrap.append(lbl, input, document.createElement('span'));
    return wrap;
  };

  const buildPixelControls = (container: HTMLElement) => {
    const ratio = Math.min(window.devicePixelRatio || 1, 2);
    container.append(
      makeColor('Color', '#f6c453', (hex) => pixelApi()?.setColor(hex)),
      makeSlider(
        { key: 'opacity' as any, label: 'Opacity', min: 0, max: 1, step: 0.01, uniform: '__opacity' },
        0.9,
        (v) => {
          const el = document.querySelector<HTMLElement>('.pixel-blast');
          if (el) el.style.opacity = String(v);
        },
      ),
    );
    for (const spec of PIXEL_SLIDERS) {
      container.appendChild(
        makeSlider(spec, PIXEL_DEFAULTS[spec.key], (v) => {
          const api = pixelApi();
          if (!api) return;
          if (spec.uniform === '__speed') {
            api.setSpeed(v);
          } else if (spec.uniform === 'uPixelSize') {
            api.setUniform('uPixelSize', v * ratio);
          } else {
            api.setUniform(spec.uniform, v);
          }
        }),
      );
    }
  };

  const buildGrainientControls = (container: HTMLElement) => {
    container.append(
      makeColor('Color 1', '#3e43b8', (hex) => grainApi()?.setColor(1, hex)),
      makeColor('Color 2', '#f6c453', (hex) => grainApi()?.setColor(2, hex)),
      makeColor('Color 3', '#2a2e8e', (hex) => grainApi()?.setColor(3, hex)),
    );
    let centerX = GRAIN_DEFAULTS.centerX;
    let centerY = GRAIN_DEFAULTS.centerY;
    for (const spec of GRAIN_SLIDERS) {
      container.appendChild(
        makeSlider(spec, GRAIN_DEFAULTS[spec.key], (v) => {
          const api = grainApi();
          if (!api) return;
          if (spec.uniform === '__centerX') {
            centerX = v;
            api.setCenter(centerX, centerY);
          } else if (spec.uniform === '__centerY') {
            centerY = v;
            api.setCenter(centerX, centerY);
          } else {
            api.setUniform(spec.uniform, v);
          }
        }),
      );
    }
    container.appendChild(
      makeCheckbox('Animate grain', true, (v) => {
        grainApi()?.setUniform('uGrainAnimated', v ? 1 : 0);
      }),
    );
  };

  const init = () => {
    const panel = document.querySelector<HTMLElement>('[data-bg-panel]');
    if (!panel) return;

    const initial = (document.documentElement.dataset.bg as 'pixel' | 'grainient' | 'none') || 'pixel';
    setActive(initial);

    panel.querySelectorAll<HTMLButtonElement>('[data-bg-set]').forEach((btn) => {
      btn.addEventListener('click', () => {
        setActive(btn.dataset.bgSet as 'pixel' | 'grainient' | 'none');
      });
    });

    const collapse = panel.querySelector<HTMLButtonElement>('[data-bg-panel-collapse]');
    collapse?.addEventListener('click', () => {
      const next = panel.dataset.collapsed === '1' ? '0' : '1';
      panel.dataset.collapsed = next;
      collapse.textContent = next === '1' ? '+' : '−';
    });

    const pxRoot = panel.querySelector<HTMLElement>('[data-pixel-controls]');
    const gnRoot = panel.querySelector<HTMLElement>('[data-grainient-controls]');
    if (pxRoot) buildPixelControls(pxRoot);
    if (gnRoot) buildGrainientControls(gnRoot);
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
</script>
